---
// Flat rank insignia for chapter level (ch-0..ch-8 = Level 1..9).
// Tiers by level: 0 steel · 1-3 silver · 4-6 amber (brand) · 7-8 amethyst.
// Matches site flat-dark + amber aesthetic: subtle fill, thin stroke, flat ink.
// Pure SVG — scalable, themeable, no raster assets.
interface Props {
  level: number; // chapter index 0..8; displayed as Level (level + 1)
  size?: number; // px, default 44
  title?: string;
}
const { level, size = 44, title } = Astro.props;
const lv = Math.max(0, Math.min(8, level));

// flat tiers: fill (subtle bg), line (stroke), ink (insignia) — on-brand alphas
const TIERS = {
  steel: { fill: "#94a3b81a", line: "#94a3b855", ink: "#cbd5e1" },
  silver: { fill: "#cbd5e11f", line: "#cbd5e166", ink: "#e2e8f0" },
  amber: { fill: "#f59e0b1f", line: "#f59e0b66", ink: "#fbbf24" },
  amethyst: { fill: "#a78bfa1f", line: "#a78bfa66", ink: "#c4b5fd" },
};
const tier =
  lv === 0
    ? TIERS.steel
    : lv <= 3
      ? TIERS.silver
      : lv <= 6
        ? TIERS.amber
        : TIERS.amethyst;

const chevrons = lv >= 1 && lv <= 3 ? lv : 0;
const stars = lv >= 4 ? (lv <= 6 ? lv - 3 : lv - 5) : 0; // 4-6 -> 1-3, 7-8 -> 2-3

function star(cx: number, cy: number, r: number) {
  const pts = [];
  for (let i = 0; i < 10; i++) {
    const ang = (Math.PI / 5) * i - Math.PI / 2;
    const rad = i % 2 === 0 ? r : r * 0.42;
    pts.push(
      `${(cx + rad * Math.cos(ang)).toFixed(1)},${(cy + rad * Math.sin(ang)).toFixed(1)}`,
    );
  }
  return "M" + pts.join("L") + "Z";
}
const starRow = (n: number, cy: number, r: number) => {
  const gap = r * 2.25;
  const x0 = 60 - ((n - 1) * gap) / 2;
  return Array.from({ length: n }, (_, i) => star(x0 + i * gap, cy, r));
};
const chevron = (i: number) => {
  const y = 49 + i * 13;
  return `M43 ${y} L60 ${y + 12} L77 ${y} L77 ${y + 7} L60 ${y + 19} L43 ${y + 7} Z`;
};
---

<svg
  width={size}
  height={size}
  viewBox="12 18 96 94"
  role="img"
  aria-label={title ?? `Level ${lv + 1}`}
  class="rank-badge"
>
  {title && <title>{title}</title>}

  {/* shield */}
  <path
    d="M30 25 L90 25 L101 64 L60 106 L19 64 Z"
    fill={tier.fill}
    stroke={tier.line}
    stroke-width="2"
    stroke-linejoin="round"></path>
  {/* thin inner outline for structure */}
  <path
    d="M37 32 L83 32 L93 64 L60 98 L27 64 Z"
    fill="none"
    stroke={tier.line}
    stroke-opacity="0.6"
    stroke-width="1"
    stroke-linejoin="round"></path>

  {/* insignia */}
  <g fill={tier.ink}>
    {
      chevrons > 0 &&
        Array.from({ length: chevrons }, (_, i) => <path d={chevron(i)} />)
    }
    {
      stars > 0 &&
        starRow(stars, 64, 12).map((d) => <path d={d} class="rbstar" />)
    }
  </g>
</svg>

<style>
  .rank-badge {
    transition: transform 0.3s cubic-bezier(0.22, 0.61, 0.36, 1);
    transform-origin: center;
  }
  /* Motion on intent only: gentle lift, matching card hover. */
  :global(.group:hover) .rank-badge,
  :global(.group:focus-within) .rank-badge {
    transform: translateY(-1px);
  }
  .rbstar {
    transform-box: fill-box;
    transform-origin: center;
  }
  @media (prefers-reduced-motion: reduce) {
    .rank-badge {
      transition: none;
    }
  }
</style>
