---
interface Props {
  name: string;
  github: string;
  role: "builder" | "mentor" | "instructor";
  skills?: string[];
  repo?: string;
  x?: string;
  linkedin?: string;
  website?: string;
  certs?: Record<string, string>;
}

const { name, github, role, skills, repo, x, linkedin, website, certs } =
  Astro.props;

import { certProgressList } from "../lib/certs.mjs";
const certList = certProgressList(certs); // earned (amber) + next 2 unearned (grey)
import { levelOf, levelMeta } from "../lib/levels.mjs";
import RankBadge from "./RankBadge.astro";
const level = levelOf(github); // highest passed chapter (0..8) or null — from progression DB
const lvl = levelMeta(level);
// Level border + glow, derived purely from Discord-verified progress (not self-declared).
const lvlStyle = lvl
  ? `border-color:${lvl.color};box-shadow:0 0 0 1px ${lvl.color}33,0 0 14px ${lvl.color}40`
  : undefined;

const avatar = `https://github.com/${github}.png?size=160`;
const roleClass =
  role === "instructor" ? "tier-c" : role === "mentor" ? "tier-b" : "tier-a";

// Normalize a handle-or-URL into a full URL.
const url = (val: string | undefined, base: string) =>
  !val
    ? undefined
    : val.startsWith("http")
      ? val
      : base + val.replace(/^@/, "");

// GitHub is already shown via the avatar + @handle link above — not repeated here.
const links = [
  { label: "Repo", href: repo, show: !!repo },
  { label: "X", href: url(x, "https://x.com/"), show: !!x },
  {
    label: "LinkedIn",
    href: url(linkedin, "https://linkedin.com/in/"),
    show: !!linkedin,
  },
  { label: "Web", href: website, show: !!website },
].filter((l) => l.show);
---

{
  /*
  Pop-out card. In a CSS grid the row height is held by sibling cells, so on
  hover/focus the inner card switches to `absolute` and grows over the row
  below (z-index) without reflowing the grid. tabindex makes it work for
  touch + keyboard, not just mouse hover.
*/
}
<div
  class="builder-cell group relative"
  data-role={role}
  data-skills={(skills ?? []).join("|")}
>
  <article
    tabindex="0"
    aria-label={`${name}, ${role}`}
    class:list={[
      "card flex cursor-pointer flex-col outline-none transition-shadow duration-200",
      "group-hover:absolute group-hover:inset-x-0 group-hover:top-0 group-hover:z-30",
      "group-hover:shadow-2xl group-hover:shadow-black/60 group-hover:ring-1 group-hover:ring-accent-500/40",
      "group-focus-within:absolute group-focus-within:inset-x-0 group-focus-within:top-0 group-focus-within:z-30",
      "group-focus-within:shadow-2xl group-focus-within:shadow-black/60 group-focus-within:ring-1 group-focus-within:ring-accent-500/40",
    ]}
  >
    <div class="flex items-center gap-3">
      <div class="avatar-wrap" style={lvlStyle}>
        <img
          src={avatar}
          alt={`${name} avatar`}
          width="52"
          height="52"
          loading="lazy"
          class="avatar-img"
        />
      </div>
      <div class="min-w-0">
        <p class="truncate font-bold text-white">{name}</p>
        <a
          href={`https://github.com/${github}`}
          target="_blank"
          rel="noopener noreferrer"
          class="font-mono text-xs text-gray-500 no-underline hover:text-accent-500"
        >
          @{github}
        </a>
      </div>
      {
        lvl && (
          <span class="ml-auto inline-flex shrink-0" aria-label={lvl.label}>
            <RankBadge
              level={level!}
              size={40}
              title={`${lvl.label} reached`}
            />
          </span>
        )
      }
      <span
        class:list={["tier", roleClass, "shrink-0", !lvl && "ml-auto"]}
        title={role}
        aria-label={`Role: ${role}`}
      >
        {role[0].toUpperCase()}
      </span>
    </div>

    {
      certList.length > 0 && (
        <div
          class="mt-3 flex flex-wrap items-center gap-2"
          aria-label="Claude certifications"
        >
          {certList.map((c) =>
            c.earned ? (
              <a
                href={c.url}
                target="_blank"
                rel="noopener noreferrer"
                class="cert-ico-link"
                style={`color:${c.color}`}
                title={`${c.label} — verified`}
                aria-label={`${c.label} — verified`}
              >
                <svg
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.9"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  class="cert-ico"
                >
                  <Fragment set:html={c.icon} />
                </svg>
              </a>
            ) : (
              <span
                class="cert-ico-link is-locked"
                style={`color:${c.color}`}
                title={`${c.label} — not yet earned`}
                aria-label={`${c.label} — not yet earned`}
              >
                <svg
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.9"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  class="cert-ico"
                >
                  <Fragment set:html={c.icon} />
                </svg>
              </span>
            ),
          )}
        </div>
      )
    }

    {
      skills && skills.length > 0 && (
        <div class="mt-3 flex flex-wrap gap-1.5">
          {skills.map((skill) => (
            <span class="rounded-full border border-white/10 bg-white/5 px-2 py-0.5 font-mono text-[10px] font-semibold text-gray-400">
              {skill}
            </span>
          ))}
        </div>
      )
    }

    <div
      class="prose-builder mt-3 line-clamp-3 text-sm text-gray-400 group-focus-within:line-clamp-none group-focus-within:max-h-72 group-focus-within:overflow-y-auto group-hover:line-clamp-none group-hover:max-h-72 group-hover:overflow-y-auto"
    >
      <slot />
    </div>

    <div
      class="mt-4 flex flex-wrap gap-x-4 gap-y-1 border-t border-white/5 pt-3 text-xs font-semibold"
    >
      {
        links.map((l) => (
          <a
            href={l.href}
            target="_blank"
            rel="noopener noreferrer"
            class="text-gray-500 no-underline hover:text-accent-500"
          >
            {l.label}
          </a>
        ))
      }
    </div>
  </article>
</div>

<style>
  .prose-builder :global(p) {
    margin: 0;
  }
  .prose-builder :global(p + p) {
    margin-top: 0.5rem;
  }

  /* ---- Avatar (squircle + subtle certified ring) ---- */
  .avatar-wrap {
    position: relative;
    flex-shrink: 0;
    width: 3.25rem;
    height: 3.25rem;
  }
  .avatar-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 30%;
    background: var(--surface-elevated, #18181b);
  }
  /* Level ring lives on the wrap (driven by inline lvlStyle from JS). */
  .avatar-wrap {
    border-radius: 32%;
    padding: 2px;
    border: 2px solid transparent;
  }
  /* ---- Cert icons (icon only, branded amber) ---- */
  .cert-ico-link {
    display: inline-flex;
    align-items: center;
    color: #f59e0b;
    text-decoration: none;
    transition:
      transform 0.15s ease,
      filter 0.15s ease;
  }
  .cert-ico-link:hover {
    transform: scale(1.25);
    filter: drop-shadow(0 0 6px currentColor);
  }
  /* Locked (not-yet-earned) targets: dim, non-interactive. */
  .cert-ico-link.is-locked {
    opacity: 0.4;
    cursor: default;
  }
  .cert-ico-link.is-locked:hover {
    transform: none;
    filter: none;
  }
  .cert-ico {
    width: 1.15rem;
    height: 1.15rem;
    display: block;
  }

  /* Keep the grid cell from collapsing when the card pops to absolute. */
  .builder-cell {
    min-height: 100%;
  }
</style>
