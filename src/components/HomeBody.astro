---
import { t, getLocale, localizedPath, type Locale } from "../i18n/utils";
import { chapters } from "../data/chapters";

const locale: Locale = getLocale(Astro.url.pathname);
const s = t(locale).home;

const features = [
  {
    icon: "⌨️",
    title: "Claude Code Deep Dive",
    desc: "Permission modes, CLAUDE.md, cost control, prompting patterns",
  },
  {
    icon: "🔌",
    title: "MCP Ecosystem",
    desc: "Context7, claude-mem, custom MCP servers for your workflow",
  },
  {
    icon: "🤖",
    title: "Agents & Skills",
    desc: "Subagents, hooks, SDK, methodologies that multiply output",
  },
  {
    icon: "🚀",
    title: "Ship to Production",
    desc: "Real URLs, security audits, deployment — not toy projects",
  },
  {
    icon: "🧭",
    title: "Tool Landscape",
    desc: "Beyond Claude: Cursor, Copilot, Aider, Windsurf",
  },
  {
    icon: "👥",
    title: "Team Build Sprint",
    desc: "Form squads, build together, Demo Day showcase",
  },
];

const tags = ["#VibeCode", "#AI", "#DEV", "#MCP", "#AGENT", "#SKILL"];

const stats = [
  { value: 185, suffix: "+", label: "Cohort 1 Builders" },
  { value: 9, suffix: "", label: "Chapters" },
  { value: 36, suffix: "h", label: "Hands-on Hours" },
  { value: 0, prefix: "$", suffix: "", label: "Cost to Join" },
];
---

<style>
  @keyframes fadeSlideUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  @keyframes fadeSlideDown {
    from {
      opacity: 0;
      transform: translateY(-12px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  /* Never from nothing: enter from scale(0.96) + opacity (Emil) */
  @keyframes fadeScaleUp {
    from {
      opacity: 0;
      transform: translateY(16px) scale(0.96);
    }
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }
  /* Slow continuous drift for depth — off main thread, reduced-motion safe */
  @keyframes auroraDrift {
    0%,
    100% {
      transform: translate3d(-8%, -4%, 0) scale(1);
    }
    50% {
      transform: translate3d(8%, 4%, 0) scale(1.15);
    }
  }
  @keyframes shimmer {
    0%,
    100% {
      background-position: -200% center;
    }
    50% {
      background-position: 200% center;
    }
  }

  .hero-badge {
    opacity: 0;
    animation: fadeSlideDown 600ms cubic-bezier(0.16, 1, 0.3, 1) 0ms forwards;
  }
  .hero-h1 {
    opacity: 0;
    animation: fadeScaleUp 800ms var(--ease-out) 100ms forwards;
  }
  .hero-stat {
    opacity: 0;
    animation: fadeSlideUp 600ms cubic-bezier(0.16, 1, 0.3, 1) 250ms forwards;
  }
  .hero-sub {
    opacity: 0;
    animation: fadeSlideUp 600ms cubic-bezier(0.16, 1, 0.3, 1) 350ms forwards;
  }
  .hero-btns {
    opacity: 0;
    animation: fadeSlideUp 600ms cubic-bezier(0.16, 1, 0.3, 1) 450ms forwards;
  }
  .hero-tags {
    opacity: 0;
    animation: fadeSlideUp 500ms cubic-bezier(0.16, 1, 0.3, 1) 550ms forwards;
  }

  .shimmer-text {
    background-size: 200% auto;
    animation: shimmer 6s ease-in-out infinite;
  }
  /* h1 carries both classes; combine entrance + shimmer so opacity reaches 1
     (a lone "animation: shimmer" would override the fade and leave it at 0). */
  .hero-h1.shimmer-text {
    animation:
      fadeScaleUp 800ms var(--ease-out) 100ms forwards,
      shimmer 6s ease-in-out infinite;
  }

  .reveal {
    opacity: 0;
    transform: translateY(24px);
    transition:
      opacity 600ms cubic-bezier(0.16, 1, 0.3, 1),
      transform 600ms cubic-bezier(0.16, 1, 0.3, 1);
  }
  .reveal.visible {
    opacity: 1;
    transform: translateY(0);
  }

  .cursor-glow {
    position: absolute;
    left: 0;
    top: 0;
    width: 400px;
    height: 400px;
    border-radius: 50%;
    background: radial-gradient(circle, #f59e0b0a, transparent 70%);
    pointer-events: none;
    transform: translate3d(-50%, -50%, 0);
    will-change: transform;
    transition: transform 300ms cubic-bezier(0.23, 1, 0.32, 1);
  }
  /* Aurora blobs — ambient depth behind hero */
  .aurora {
    position: absolute;
    border-radius: 9999px;
    filter: blur(48px);
    pointer-events: none;
    will-change: transform;
    opacity: 0.7;
  }
  .aurora-1 {
    left: 8%;
    top: -12%;
    width: 380px;
    height: 380px;
    background: radial-gradient(circle, #f59e0b14, transparent 70%);
    animation: auroraDrift 14s var(--ease-in-out) infinite;
  }
  .aurora-2 {
    right: 4%;
    top: 8%;
    width: 300px;
    height: 300px;
    background: radial-gradient(circle, #f59e0b0f, transparent 70%);
    animation: auroraDrift 18s var(--ease-in-out) infinite reverse;
  }

  /* Cursor-tracked spotlight on cards (Linear/Vercel style) */
  .spotlight-glow {
    position: absolute;
    inset: 0;
    border-radius: inherit;
    pointer-events: none;
    opacity: 0;
    transition: opacity 300ms var(--ease-out);
    background: radial-gradient(
      280px circle at var(--mx, 50%) var(--my, 50%),
      #f59e0b1f,
      transparent 60%
    );
  }
  @media (hover: hover) and (pointer: fine) {
    .spotlight:hover .spotlight-glow {
      opacity: 1;
    }
  }
  /* 3D flip cards — Emil: preserve-3d + backface-hidden, ease-in-out morph */
  .flip-card {
    perspective: 1000px;
  }
  .flip-inner {
    position: relative;
    width: 100%;
    min-height: 152px;
    transform-style: preserve-3d;
    transition: transform 600ms var(--ease-in-out);
  }
  .flip-face {
    position: absolute;
    inset: 0;
    -webkit-backface-visibility: hidden;
    backface-visibility: hidden;
  }
  .flip-back {
    transform: rotateY(180deg);
  }
  @media (hover: hover) and (pointer: fine) {
    .flip-card:hover .flip-inner {
      transform: rotateY(180deg);
    }
  }

  /* ---- Hero avatar mosaic (single composite WebP, see scripts/hero) ---- */
  .hero-mosaic {
    position: absolute;
    inset: -6%;
    background: url("/hero-mosaic.webp") center / cover no-repeat;
    opacity: 0.22;
    filter: saturate(0.85);
    will-change: transform;
    animation: heroDrift 40s ease-in-out infinite alternate;
  }
  .hero-mosaic-veil {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(
        820px 460px at 50% 42%,
        #09090bf2 0%,
        #09090b80 56%,
        transparent 80%
      ),
      linear-gradient(
        180deg,
        #09090bd9 0%,
        #09090b99 32%,
        #09090be6 70%,
        #09090b 100%
      );
  }
  @keyframes heroDrift {
    from {
      transform: scale(1.06) translate(-1%, -1%);
    }
    to {
      transform: scale(1.12) translate(1%, 1%);
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .hero-mosaic {
      animation: none;
      transform: scale(1.06);
    }
    /* show hero content without entrance motion */
    .hero-badge,
    .hero-h1,
    .hero-stat,
    .hero-sub,
    .hero-btns,
    .hero-tags {
      opacity: 1;
      animation: none;
    }
  }
</style>

<!-- Hero -->
<section id="hero" class="relative overflow-hidden py-20 text-center sm:py-28">
  <div class="hero-mosaic" aria-hidden="true"></div>
  <div class="hero-mosaic-veil" aria-hidden="true"></div>
  <div
    class="pointer-events-none absolute left-1/2 top-0 h-[400px] w-[600px] -translate-x-1/2 rounded-full"
    style="background: radial-gradient(circle, #f59e0b0d, transparent 70%)"
  >
  </div>
  <span class="aurora aurora-1 hidden sm:block" aria-hidden="true"></span>
  <span class="aurora aurora-2 hidden sm:block" aria-hidden="true"></span>
  <div id="cursor-glow" class="cursor-glow hidden sm:block"></div>
  <div class="relative z-10 mx-auto max-w-3xl px-5 sm:px-6">
    <div
      class="hero-badge mb-6 inline-flex items-center gap-2 rounded-full border border-accent-500/30 bg-accent-500/10 px-4 py-1.5 text-sm font-semibold text-accent-500"
    >
      <span class="h-1.5 w-1.5 animate-pulse rounded-full bg-accent-500"></span>
      Cohort 1 in progress · Cohort 2 opens October 2026
    </div>
    <h1
      class="hero-h1 shimmer-text text-4xl font-black leading-tight sm:text-6xl"
      style="background: linear-gradient(135deg, #fff 0%, #f59e0b 50%, #fff 80%, #f59e0b 100%); background-size: 200% auto; -webkit-background-clip: text; -webkit-text-fill-color: transparent;"
    >
      Master AI-First Development
    </h1>
    <p class="hero-stat mt-4 text-lg font-bold text-accent-500">{s.heroStat}</p>
    <p class="hero-sub mx-auto mt-4 max-w-xl text-lg text-gray-400">
      {s.heroSub}
    </p>
    <div
      class="hero-btns mt-8 flex flex-col items-center justify-center gap-3 sm:flex-row"
    >
      <a href={localizedPath("/apply", locale)} class="btn btn-primary"
        >{s.ctaApply}</a
      >
      <a href={localizedPath("/curriculum", locale)} class="btn btn-secondary"
        >{s.ctaWork}</a
      >
    </div>
    <div class="hero-tags mt-6 flex flex-wrap justify-center gap-2">
      {
        tags.map((tag) => (
          <span class="rounded-full border border-accent-500/20 bg-accent-500/[0.07] px-3 py-1 font-mono text-xs font-semibold text-accent-500/90 transition-all duration-200 hover:border-accent-500/40 hover:bg-accent-500/10 hover:text-accent-500">
            {tag}
          </span>
        ))
      }
    </div>
  </div>
</section>

<!-- Features -->
<section class="reveal mx-auto max-w-5xl px-5 py-12 sm:px-6">
  <p class="section-label">What You'll Master</p>
  <h2 class="mt-2 text-center text-3xl font-extrabold sm:text-4xl">
    Build with AI, Not Just About AI
  </h2>
  <div class="mt-10 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
    {
      features.map((f, i) => (
        <div class="flip-card reveal" style={`transition-delay: ${i * 80}ms`}>
          <div class="flip-inner">
            <div class="flip-face flex h-full flex-col rounded-xl border border-white/5 bg-surface-card p-6">
              <div class="mb-3 flex h-10 w-10 items-center justify-center rounded-lg border border-accent-500/20 bg-accent-500/10 text-xl">
                {f.icon}
              </div>
              <h3 class="text-base font-bold">{f.title}</h3>
              <p class="mt-auto pt-3 font-mono text-[10px] font-semibold uppercase tracking-widest text-accent-500/50">
                Hover →
              </p>
            </div>
            <div
              class="flip-face flip-back flex h-full flex-col justify-center rounded-xl border border-accent-500/25 p-6"
              style="background: linear-gradient(135deg, #f59e0b14, #09090b)"
            >
              <h3 class="text-sm font-bold text-accent-500">{f.title}</h3>
              <p class="mt-2 text-sm text-gray-300">{f.desc}</p>
            </div>
          </div>
        </div>
      ))
    }
  </div>
</section>

<!-- Curriculum Roadmap -->
<section class="reveal mx-auto max-w-5xl px-5 py-16 sm:px-6">
  <p class="section-label">The Journey</p>
  <h2 class="mt-2 text-center text-3xl font-extrabold sm:text-4xl">
    9 Chapters · Zero to Ship
  </h2>
  <div class="mt-10 grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
    {
      chapters.map((ch, i) => (
        <a
          href={localizedPath(`/curriculum/ch-${ch.num}`, locale)}
          class="reveal spotlight group overflow-hidden rounded-xl border border-white/5 bg-surface-card p-5 no-underline transition-all duration-300 hover:-translate-y-0.5 hover:border-accent-500/20"
          style={`transition-delay: ${i * 60}ms`}
        >
          <span class="spotlight-glow" aria-hidden="true" />
          <div class="font-mono text-xs font-bold text-accent-500/70">
            CH {ch.num}
          </div>
          <h3 class="mt-1 text-sm font-bold text-white">{ch.title}</h3>
          <p class="mt-1 text-xs text-gray-600">{ch.outcome}</p>
          <div class="mt-3 flex gap-1">
            {ch.tiers.map((tier) => (
              <span
                class:list={["tier", `tier-${tier.toLowerCase()}`]}
                title={`Tier ${tier}`}
              >
                {tier}
              </span>
            ))}
          </div>
        </a>
      ))
    }
  </div>
</section>

<!-- Social Proof -->
<section id="stats-section" class="reveal mx-auto max-w-4xl px-5 py-12 sm:px-6">
  <div
    class="flex flex-wrap justify-center gap-12 rounded-xl border border-white/5 bg-surface-card px-8 py-8 sm:gap-16"
  >
    {
      stats.map((s) => (
        <div class="text-center">
          <div class="text-3xl font-black text-white">
            {s.prefix && <span>{s.prefix}</span>}
            <span class="counter" data-target={s.value}>
              0
            </span>
            {s.suffix && <span class="text-accent-500">{s.suffix}</span>}
          </div>
          <div class="mt-1 text-xs text-gray-500">{s.label}</div>
        </div>
      ))
    }
  </div>
</section>

<!-- Final CTA -->
<section class="reveal mx-auto max-w-3xl px-5 py-16 sm:px-6">
  <div
    class="relative overflow-hidden rounded-2xl border border-accent-500/20 p-12 text-center transition-all duration-500 hover:border-accent-500/30"
    style="background: linear-gradient(135deg, #f59e0b0d, #09090b)"
  >
    <div
      class="pointer-events-none absolute inset-0"
      style="background: radial-gradient(circle at center, #f59e0b08, transparent 50%)"
    >
    </div>
    <h2 class="relative text-3xl font-extrabold">Ready to Vibe Code?</h2>
    <p class="relative mt-3 text-gray-500">
      Join the next cohort and build with AI, not just about it.
    </p>
    <div class="relative mt-6">
      <a href={localizedPath("/apply", locale)} class="btn btn-primary text-lg"
        >{s.ctaApply}</a
      >
    </div>
  </div>
</section>

<script>
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add("visible");
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.1, rootMargin: "0px 0px -40px 0px" },
  );

  document.querySelectorAll(".reveal").forEach((el) => observer.observe(el));

  const counterObserver = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.querySelectorAll(".counter").forEach((counter) => {
            const target = parseInt(
              (counter as HTMLElement).dataset.target ?? "0",
              10,
            );
            if (target === 0) {
              counter.textContent = "0";
              return;
            }
            const duration = 1500;
            const start = performance.now();
            const step = (now: number) => {
              const elapsed = now - start;
              const progress = Math.min(elapsed / duration, 1);
              const eased = 1 - Math.pow(1 - progress, 4);
              counter.textContent = Math.round(eased * target).toString();
              if (progress < 1) requestAnimationFrame(step);
            };
            requestAnimationFrame(step);
          });
          counterObserver.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.3 },
  );

  const statsEl = document.getElementById("stats-section");
  if (statsEl) counterObserver.observe(statsEl);

  const hero = document.getElementById("hero");
  const glow = document.getElementById("cursor-glow");
  if (hero && glow) {
    const move = (x: number, y: number) => {
      (glow as HTMLElement).style.transform =
        `translate3d(calc(${x}px - 50%), calc(${y}px - 50%), 0)`;
    };
    // center initially
    move(hero.offsetWidth / 2, hero.offsetHeight / 2);
    hero.addEventListener("mousemove", (e) => {
      const rect = hero.getBoundingClientRect();
      move(e.clientX - rect.left, e.clientY - rect.top);
    });
    hero.addEventListener("mouseleave", () => {
      move(hero.offsetWidth / 2, hero.offsetHeight / 2);
    });
  }
  // Cursor-tracked spotlight (hover devices only, rAF-throttled)
  if (window.matchMedia("(hover: hover) and (pointer: fine)").matches) {
    document.querySelectorAll<HTMLElement>(".spotlight").forEach((card) => {
      let raf = 0;
      card.addEventListener("mousemove", (e) => {
        if (raf) return;
        raf = requestAnimationFrame(() => {
          const r = card.getBoundingClientRect();
          card.style.setProperty("--mx", `${e.clientX - r.left}px`);
          card.style.setProperty("--my", `${e.clientY - r.top}px`);
          raf = 0;
        });
      });
    });
  }
</script>
